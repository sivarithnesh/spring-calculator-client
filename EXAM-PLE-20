2) QRY_PRODUCTIVITY_CHILDBREAKS_SEB
SELECT
    'SEB' AS SOURCEDB,
    TLMADM_ITEM.LAST_ACTION_OWNER AS USERID
FROM TLMADM_BANK
INNER JOIN TLMADM_ITEM
    ON TLMADM_BANK.CORR_ACC_NO = TLMADM_ITEM.CORR_ACC_NO
WHERE
(
    TLMADM_BANK.AGENT_CODE = 'MUTUAL FUNDS- SEB'
    AND TLMADM_ITEM.LS_TYPE NOT IN (9030, 9099)
    AND TLMADM_ITEM.FLAG_2 = 0
    AND TLMADM_ITEM.REASON_TYPE_ID <> 100000057
)
GROUP BY
    TLMADM_ITEM.LAST_ACTION_OWNER;

