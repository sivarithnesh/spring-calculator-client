1) QRY_PRODUCTIVITY_CHILDBREAKS_PSUEDOS
SELECT
    TLMADM_BANK.AGENT_CODE AS SOURCE,
    TLMADM_ITEM.LAST_ACTION_OWNER AS USERID
FROM TLMADM_BANK
INNER JOIN TLMADM_ITEM
    ON TLMADM_BANK.CORR_ACC_NO = TLMADM_ITEM.CORR_ACC_NO
WHERE
(
    (
        TLMADM_BANK.AGENT_CODE IN
        (
            'MUTUAL FUNDS - NSCC TRANS POS',
            'MUTUAL FUNDS - MONTHLY POSITIONS'
        )
        OR TLMADM_BANK.AGENT_CODE LIKE 'MUTUAL FUNDS - SWIFT DAILY POSITIONS%'
        OR TLMADM_BANK.AGENT_CODE LIKE 'MUTUAL FUNDS - HEDGE%'
    )
    AND TLMADM_ITEM.LS_TYPE NOT IN (9030, 9099)
    AND TLMADM_ITEM.FLAG_2 = 0
    AND TLMADM_ITEM.REASON_TYPE_ID <> 100000057
)
GROUP BY
    TLMADM_BANK.AGENT_CODE,
    TLMADM_ITEM.LAST_ACTION_OWNER;
	
