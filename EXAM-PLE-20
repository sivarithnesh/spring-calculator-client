(SELECT
    B.AGENT_CODE AS AGENT_CODE,
    B.LOCAL_ACC_NO AS LOCAL_ACC_NO,

    CASE
        WHEN STOCK_CODE IS NULL THEN 'N/A'
        ELSE STOCK_CODE
    END AS ISIN,

    I.STRING_27 AS SecID ,
    I.STRING_28 AS SecName,

    CASE
        WHEN LS_TYPE = 9030
        THEN AMOUNT_6
        ELSE 0
    END AS BbhAmount,

    CASE
        WHEN LS_TYPE = 9030
        THEN 0
        ELSE AMOUNT_6
    END AS NsccAmount,
	
	
WITH qry_NewMsgFeedData_Hedge_Only AS
(
    SELECT DISTINCT
        B.LOCAL_ACC_NO,
        MF.BSLA AS [Contact #],
        MF.BUS_CODE AS [Initial Method],
        MF.BUS_OWNER AS [TA Email ID]
    FROM TLMADM_BANK B
    INNER JOIN TLMADM_MESSAGE_FEED MF
        ON B.CORR_ACC_NO = MF.CORR_ACC_NO
    WHERE MF.STATUS = 0
        AND B.AGENT_CODE LIKE 'MUTUAL FUNDS - HEDGE%'
        AND MF.BSLA IS NOT NULL
),

qry_NewMsgFeedData_Monthly_Only AS
(
    SELECT DISTINCT
        B.LOCAL_ACC_NO,
        MF.BSLA AS [Contact #],
        MF.BUS_CODE AS [Initial Method],
        MF.BUS_OWNER AS [TA Email ID]
    FROM TLMADM_BANK B
    INNER JOIN TLMADM_MESSAGE_FEED MF
        ON B.CORR_ACC_NO = MF.CORR_ACC_NO
    WHERE MF.STATUS = 0
        AND B.AGENT_CODE = 'MUTUAL FUNDS - MONTHLY POSITIONS'
        AND MF.BSLA IS NOT NULL
),

qry_NewMsgFeedData_NSCC_Only AS
(
    SELECT DISTINCT
        B.LOCAL_ACC_NO,
        MF.BSLA AS [Contact #],
        MF.BUS_CODE AS [Initial Method],
        MF.BUS_OWNER AS [TA Email ID]
    FROM TLMADM_BANK B
    INNER JOIN TLMADM_MESSAGE_FEED MF
        ON B.CORR_ACC_NO = MF.CORR_ACC_NO
    WHERE MF.STATUS = 0
        AND B.AGENT_CODE = 'MUTUAL FUNDS - NSCC TRANS POS'
        AND MF.BSLA IS NOT NULL
),

qry_NewMsgFeedData_SwiftDaily_Only AS
(
    SELECT
        MF.SUB_ACC_NO AS SUB_ACC_NO,
        B.LOCAL_ACC_NO,
        MF.DESCRIPTION AS [Statement Expected],
        MF.BSLA AS [Contact #],
        MF.BUS_CODE AS [Initial Method],
        MF.BUS_OWNER AS [TA Email ID]
    FROM TLMADM_BANK B
    INNER JOIN TLMADM_MESSAGE_FEED MF
        ON B.CORR_ACC_NO = MF.CORR_ACC_NO
    WHERE MF.STATUS = 0
        AND B.AGENT_CODE LIKE 'MUTUAL FUNDS - SWIFT DAILY POSITIONS%'
        AND MF.BSLA IS NOT NULL
)

SELECT
    'Hedge' AS MsgFeedType,
    LOCAL_ACC_NO,
    COUNT(LOCAL_ACC_NO) AS CountOfLOCAL_ACC_NO,
    MIN([Contact #]) AS FirstOfContact,
    MAX([Contact #]) AS LastOfContact,
    MIN([Initial Method]) AS FirstOfInitialMethod,
    MAX([Initial Method]) AS LastOfInitialMethod,
    MIN([TA Email ID]) AS FirstOfTAEmailID,
    MAX([TA Email ID]) AS LastOfTAEmailID
FROM qry_NewMsgFeedData_Hedge_Only
GROUP BY LOCAL_ACC_NO
HAVING COUNT(LOCAL_ACC_NO) > 1

UNION ALL

SELECT
    'Monthly' AS MsgFeedType,
    LOCAL_ACC_NO,
    COUNT(LOCAL_ACC_NO) AS CountOfLOCAL_ACC_NO,
    MIN([Contact #]) AS FirstOfContact,
    MAX([Contact #]) AS LastOfContact,
    MIN([Initial Method]) AS FirstOfInitialMethod,
    MAX([Initial Method]) AS LastOfInitialMethod,
    MIN([TA Email ID]) AS FirstOfTAEmailID,
    MAX([TA Email ID]) AS LastOfTAEmailID
FROM qry_NewMsgFeedData_Monthly_Only
GROUP BY LOCAL_ACC_NO
HAVING COUNT(LOCAL_ACC_NO) > 1

UNION ALL

SELECT
    'Swift' AS MsgFeedType,
    LOCAL_ACC_NO,
    COUNT(LOCAL_ACC_NO) AS CountOfLOCAL_ACC_NO,
    MIN([Contact #]) AS FirstOfContact,
    MAX([Contact #]) AS LastOfContact,
    MIN([Initial Method]) AS FirstOfInitialMethod,
    MAX([Initial Method]) AS LastOfInitialMethod,
    MIN([TA Email ID]) AS FirstOfTAEmailID,
    MAX([TA Email ID]) AS LastOfTAEmailID
FROM qry_NewMsgFeedData_SwiftDaily_Only
GROUP BY LOCAL_ACC_NO
HAVING COUNT(LOCAL_ACC_NO) > 1

UNION ALL

SELECT
    'NSCC' AS MsgFeedType,
    LOCAL_ACC_NO,
    COUNT(LOCAL_ACC_NO) AS CountOfLOCAL_ACC_NO,
    MIN([Contact #]) AS FirstOfContact,
    MAX([Contact #]) AS LastOfContact,
    MIN([Initial Method]) AS FirstOfInitialMethod,
    MAX([Initial Method]) AS LastOfInitialMethod,
    MIN([TA Email ID]) AS FirstOfTAEmailID,
    MAX([TA Email ID]) AS LastOfTAEmailID
FROM qry_NewMsgFeedData_NSCC_Only
GROUP BY LOCAL_ACC_NO
HAVING COUNT(LOCAL_ACC_NO) > 1
