3) qry_productivity_mfinputs
SELECT
    TLMADM_BANK.AGENT_CODE AS CATEGORY,
    SUBSTR(STRING_24, 1, 7) AS INPUTBY
FROM TLMADM_BANK
INNER JOIN TLMADM_ITEM
    ON TLMADM_BANK.CORR_ACC_NO = TLMADM_ITEM.CORR_ACC_NO
WHERE
(
    SUBSTR(STRING_24, 1, 7) LIKE 'A0%'
    AND TLMADM_BANK.AGENT_CODE LIKE 'MUTUAL FUNDS -%'
    AND TLMADM_ITEM.LS_TYPE = 9099
    AND TLMADM_ITEM.SYS_ENTRY_DATE
        BETWEEN :START_DATE AND :END_DATE
)
GROUP BY
    TLMADM_BANK.AGENT_CODE,
    SUBSTR(STRING_24, 1, 7);
	
