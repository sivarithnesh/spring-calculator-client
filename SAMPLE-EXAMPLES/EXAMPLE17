(SELECT
    B.AGENT_CODE AS AGENT_CODE,
    B.LOCAL_ACC_NO AS LOCAL_ACC_NO,

    CASE
        WHEN STOCK_CODE IS NULL THEN 'N/A'
        ELSE STOCK_CODE
    END AS ISIN,

    I.STRING_27 AS SecID ,
    I.STRING_28 AS SecName,

    CASE
        WHEN LS_TYPE = 9030
        THEN AMOUNT_6
        ELSE 0
    END AS BbhAmount,

    CASE
        WHEN LS_TYPE = 9030
        THEN 0
        ELSE AMOUNT_6
    END AS NsccAmount,

    I.STMT_DATE AS Statement,

    CASE
        WHEN STRING_14 <> ' '
        THEN STRING_14
        ELSE
            CASE
                WHEN SUBSTR(LOCAL_ACC_NO, 8, 1) = '-'
                THEN SUBSTR(LOCAL_ACC_NO, 1, 7)
                ELSE 'OMNIBUS'
            END
    END AS BbhAcctNum,

    I.STRING_21 AS BBHExtAcctNum,
    I.STRING_21 AS NsccExtAcctNum,

    I.AMOUNT_5 AS Price,

    'System Entry Date = ' || SYS_ENTRY_DATE AS HitsTlm,

   	CASE
    WHEN B.AGENT_CODE LIKE '%MUTUAL FUNDS - NSCC TRANS POS%'
        THEN 'NSCC'

    WHEN B.AGENT_CODE LIKE '%MUTUAL FUNDS - MONTHLY POSITIONS%'
        THEN 'MONTHLY'

    WHEN B.AGENT_CODE LIKE '%MUTUAL FUNDS - SWIFT DAILY POSITIONS%'
        THEN 'SWIFTDAILY'

    WHEN B.AGENT_CODE LIKE '%MUTUAL FUNDS - HEDGE%'
        THEN 'HEDGE'
END AS SOURCEDB,

    I.STRING_29 AS BbhAcctName,

    I.STRING_13 AS Freq

FROM BANK B
INNER JOIN ITEM I
    ON B.CORR_ACC_NO = I.CORR_ACC_NO

LEFT JOIN STCK STCK
    ON I.STOCK_ID = STCK.STOCK_ID

WHERE (  B.AGENT_CODE LIKE '%MUTUAL FUNDS - NSCC TRANS POS%'
    OR B.AGENT_CODE LIKE '%MUTUAL FUNDS - MONTHLY POSITIONS%'
    OR B.AGENT_CODE LIKE '%MUTUAL FUNDS - SWIFT DAILY POSITIONS%'
    OR B.AGENT_CODE LIKE '%MUTUAL FUNDS - HEDGE%' )

AND I.LS_TYPE IN (9030, 9099)

AND I.FLAG_2 = 0 )

=============================================================

SELECT
    B.LOCAL_ACC_NO AS LOCAL_ACC_NO,

    CASE
        WHEN STOCK_CODE IS NULL THEN 'N/A'
        ELSE STOCK_CODE
    END AS ISIN,

    CASE
        WHEN STRING_14 <> ' '
        THEN STRING_14
        ELSE
            CASE
                WHEN SUBSTR(LOCAL_ACC_NO, 8, 1) = '-'
                THEN SUBSTR(LOCAL_ACC_NO, 1, 7)
                ELSE 'OMNIBUS'
            END
    END AS BbhAcctNum,

    I.STMT_DATE as Statement,

    CASE
        WHEN LS_TYPE IN (9106, 9129)
        THEN AMOUNT_6 * -1
        ELSE AMOUNT_6
    END AS BreakQuantity,

    TRUNC(SYS_ENTRY_DATE) AS BreakOpened,

    I.ITEM_ID AS BreakDesc,
    I.STRING_6 as AuditTrail,

    DCOD.CODE_NAME as BreakType,

    TLM_REF_REASON_CATEGORY.NAME AS ReasonCategory,

	TLM_REF_REASON_CATEGORY.NAME AS DEPT,


      	CASE
    WHEN B.AGENT_CODE LIKE '%MUTUAL FUNDS - NSCC TRANS POS%'
        THEN 'NSCC'

    WHEN B.AGENT_CODE LIKE '%MUTUAL FUNDS - MONTHLY POSITIONS%'
        THEN 'MONTHLY'

    WHEN B.AGENT_CODE LIKE '%MUTUAL FUNDS - SWIFT DAILY POSITIONS%'
        THEN 'SWIFTDAILY'

    WHEN B.AGENT_CODE LIKE '%MUTUAL FUNDS - HEDGE%'
        THEN 'HEDGE'
END AS SOURCEDB,

    TLM_REF_REASON_TYPE.NAME AS ReasonType,

    TLM_BDR_NOTE.NOTE AS Comments,

    I.ITEM_ID,

    CASE
        WHEN LS_TYPE IN (9105, 9106)
        THEN REFERENCE
        ELSE ''
    END AS TAExtAcctNum,

    CASE
        WHEN LS_TYPE IN (9128, 9129)
        THEN STRING_21
        ELSE ''
    END AS BbhExtAcctNum

FROM BANK

INNER JOIN ITEM
    ON B.CORR_ACC_NO = I.CORR_ACC_NO

LEFT JOIN DCOD
    ON I.BRAN_CODE = DCOD.CODEC

LEFT JOIN STCK
    ON I.STOCK_ID = STCK.STOCK_ID

LEFT JOIN TLM_REF_REASON_TYPE
    ON I.REASON_TYPE_ID =
       TLM_REF_REASON_TYPE.REASON_TYPE_ID

LEFT JOIN TLM_REF_REASON_CATEGORY
    ON TLM_REF_REASON_TYPE.REASON_CATEGORY_ID =
       TLM_REF_REASON_CATEGORY.REASON_CATEGORY_ID

LEFT JOIN TLM_BDR_NOTE
    ON I.NOTE_ID =
       TLM_BDR_NOTE.ID

WHERE  (  B.AGENT_CODE LIKE '%MUTUAL FUNDS - NSCC TRANS POS%'
    OR B.AGENT_CODE LIKE '%MUTUAL FUNDS - MONTHLY POSITIONS%'
    OR B.AGENT_CODE LIKE '%MUTUAL FUNDS - SWIFT DAILY POSITIONS%'
    OR B.AGENT_CODE LIKE '%MUTUAL FUNDS - HEDGE%' )

AND I.LS_TYPE NOT IN (9030, 9099)

AND I.FLAG_2 = 0;
