SELECT
    B.AGENT_CODE AS CATEGORY,
    SUBSTR(I.STRING_24,1,7) AS INPUTBY,
    TRUNC(I.SYS_ENTRY_DATE) AS ENTRY_DATE,
    COUNT(*) AS RECORD_COUNT
FROM BANK B
JOIN ITEM I
    ON B.CORR_ACC_NO = I.CORR_ACC_NO
WHERE SUBSTR(I.STRING_24,1,7) LIKE 'A0%'
  AND B.AGENT_CODE LIKE 'MUTUAL FUNDS -%'
  AND I.LS_TYPE = 9099
  AND I.SYS_ENTRY_DATE BETWEEN :STARTDATE AND :ENDDATE
GROUP BY
    B.AGENT_CODE,
    SUBSTR(I.STRING_24,1,7),
    TRUNC(I.SYS_ENTRY_DATE)
ORDER BY
    B.AGENT_CODE,
    SUBSTR(I.STRING_24,1,7),
    TRUNC(I.SYS_ENTRY_DATE);
